{
    "$schema": "https://schema.railway.app/railway.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd frontend && npm install && npm run build"
    },
    "deploy": {
        "startCommand": "cd frontend && npm start",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
    }
}